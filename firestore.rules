rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /medicamentos/{document} {
      allow read, write: if true;
    }

    match /clientes/{document} {
      allow read, write: if true;
    }

    match /pedidos/{document} {
      allow read, write: if true;
    }
  }
}
